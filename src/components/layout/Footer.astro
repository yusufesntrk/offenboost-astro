---
const currentYear = new Date().getFullYear();
---

<footer class="py-16 px-4 md:px-8">
  <div class="max-w-6xl mx-auto">
    <div class="bg-card rounded-3xl p-8 md:p-12 shadow-card border border-border/50">
      <div class="grid md:grid-cols-4 gap-8 items-start">
        <!-- Logo & Tagline -->
        <div class="space-y-4 md:col-span-1">
          <a href="/" class="flex items-center gap-2 min-h-[44px]">
            <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white">
                <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
                <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
                <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>
                <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>
              </svg>
            </div>
            <span class="font-bold text-lg text-secondary">
              Offen<span class="text-primary">Boost</span>
            </span>
          </a>
          <p class="text-muted-foreground text-sm">
            Ihr Wachstumspartner aus Offenburg.
          </p>
        </div>

        <!-- Useful Links -->
        <div>
          <h4 class="font-semibold text-foreground mb-4">Seiten</h4>
          <nav class="flex flex-col gap-1">
            <a
              href="/"
              class="text-muted-foreground hover:text-foreground transition-colors text-sm py-2 min-h-[44px] flex items-center"
            >
              Startseite
            </a>
            <a
              href="/leistungen"
              class="text-muted-foreground hover:text-foreground transition-colors text-sm py-2 min-h-[44px] flex items-center"
            >
              Leistungen
            </a>
            <a
              href="/ueber-uns"
              class="text-muted-foreground hover:text-foreground transition-colors text-sm py-2 min-h-[44px] flex items-center"
            >
              Über uns
            </a>
            <a
              href="/termin"
              class="text-muted-foreground hover:text-foreground transition-colors text-sm py-2 min-h-[44px] flex items-center"
            >
              Termin buchen
            </a>
          </nav>
        </div>

        <!-- Services -->
        <div>
          <h4 class="font-semibold text-foreground mb-4">Leistungen</h4>
          <nav class="flex flex-col gap-1">
            <span class="text-muted-foreground text-sm py-2 min-h-[44px] flex items-center">
              Marketing & Growth
            </span>
            <span class="text-muted-foreground text-sm py-2 min-h-[44px] flex items-center">
              Sales-Systeme
            </span>
            <span class="text-muted-foreground text-sm py-2 min-h-[44px] flex items-center">
              Webentwicklung
            </span>
            <span class="text-muted-foreground text-sm py-2 min-h-[44px] flex items-center">
              Beratung
            </span>
          </nav>
        </div>

        <!-- Legal Links -->
        <div>
          <h4 class="font-semibold text-foreground mb-4">Rechtliches</h4>
          <nav class="flex flex-col gap-1">
            <a
              href="/datenschutz"
              class="text-muted-foreground hover:text-foreground transition-colors text-sm py-2 min-h-[44px] flex items-center"
            >
              Datenschutz
            </a>
            <a
              href="/agb"
              class="text-muted-foreground hover:text-foreground transition-colors text-sm py-2 min-h-[44px] flex items-center"
            >
              AGB
            </a>
            <a
              href="/impressum"
              class="text-muted-foreground hover:text-foreground transition-colors text-sm py-2 min-h-[44px] flex items-center"
            >
              Impressum
            </a>
          </nav>
        </div>
      </div>

      <div class="mt-12 pt-8 border-t border-border">
        <p class="text-muted-foreground text-sm text-center">
          © {currentYear} OffenBoost. Alle Rechte vorbehalten.
        </p>
      </div>
    </div>
  </div>
</footer>
