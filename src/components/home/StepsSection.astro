---
const steps = [
  {
    number: "01",
    title: "Erstgespräch",
    description: "Wir lernen Sie und Ihr Unternehmen kennen. Im kostenlosen Erstgespräch analysieren wir Ihre aktuelle Situation.",
  },
  {
    number: "02",
    title: "Strategie",
    description: "Basierend auf Ihren Zielen entwickeln wir eine maßgeschneiderte Strategie für nachhaltiges Wachstum.",
  },
  {
    number: "03",
    title: "Umsetzung",
    description: "Wir setzen die Strategie professionell um und liefern messbare Ergebnisse.",
  },
  {
    number: "04",
    title: "Optimierung",
    description: "Kontinuierliche Analyse und Optimierung für maximale Performance und langfristigen Erfolg.",
  },
];
---

<section class="py-16 md:py-24 px-4 md:px-8">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <p class="text-primary font-medium mb-4">Unser Prozess</p>
      <h2 class="section-heading mb-4">
        So arbeiten wir <span class="gradient-text">zusammen</span>
      </h2>
      <p class="section-subheading mx-auto">
        Ein klarer, strukturierter Prozess für maximale Effizienz und beste Ergebnisse.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid md:grid-cols-4 gap-8">
      {steps.map((step, index) => (
        <div
          class="text-center animate-fade-in-up relative"
          style={`animation-delay: ${index * 150}ms`}
        >
          <!-- Connector Line (hidden on mobile and last item) -->
          {index < steps.length - 1 && (
            <div class="hidden md:block absolute top-8 left-[60%] w-[80%] h-[2px] bg-gradient-to-r from-primary/30 to-transparent" />
          )}

          <div class="text-5xl font-bold text-primary/20 mb-4">
            {step.number}
          </div>
          <h3 class="text-xl font-semibold text-foreground mb-3">
            {step.title}
          </h3>
          <p class="text-muted-foreground text-sm">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
