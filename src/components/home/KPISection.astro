---
const kpis = [
  { value: "100+", label: "Erfolgreich umgesetzte Projekte" },
  { value: "50+", label: "Zufriedene Kunden" },
  { value: "4+", label: "Jahre Erfahrung" },
  { value: "24h", label: "Durchschnittliche Reaktionszeit" },
];
---

<section class="py-16 md:py-24 px-4 md:px-8">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="section-heading mb-4">
        Zahlen, die <span class="gradient-text">überzeugen</span>
      </h2>
      <p class="section-subheading mx-auto">
        Unsere Erfahrung und unser Engagement spiegeln sich in unseren Ergebnissen wider.
      </p>
    </div>

    <!-- KPI Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      {kpis.map((kpi, index) => (
        <div
          class="feature-card text-center animate-fade-in-up"
          style={`animation-delay: ${index * 100}ms`}
        >
          <div class="text-3xl md:text-4xl font-bold gradient-text mb-2">
            {kpi.value}
          </div>
          <p class="text-sm text-muted-foreground">{kpi.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
