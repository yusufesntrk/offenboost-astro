---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PAGE_SEO } from '../lib/seo-config';
import { Home, ArrowLeft } from 'lucide-react';
---

<BaseLayout
  title={PAGE_SEO.notFound.title}
  description={PAGE_SEO.notFound.description}
  noindex={true}
>
  <main class="min-h-[calc(100vh-200px)] flex items-center justify-center px-4">
    <div class="text-center max-w-md">
      <div class="text-8xl font-bold gradient-text mb-4">404</div>
      <h1 class="text-2xl font-bold text-foreground mb-4">
        Seite nicht gefunden
      </h1>
      <p class="text-muted-foreground mb-8">
        Die angeforderte Seite existiert leider nicht. Möglicherweise wurde
        sie verschoben oder gelöscht.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-primary hover:bg-primary/90 text-white font-semibold rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg shadow-md shadow-primary/25"
        >
          <Home className="w-4 h-4" />
          Zur Startseite
        </a>
        <button
          onclick="window.history.back()"
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 bg-card hover:bg-muted text-foreground font-semibold rounded-xl border border-border transition-all"
        >
          <ArrowLeft className="w-4 h-4" />
          Zurück
        </button>
      </div>
    </div>
  </main>
</BaseLayout>
